	<license>https://www.gnu.org/copyleft/gpl.html GNU/GPL</license>
	<authorEmail>info@radicalmart.ru</authorEmail>
	<authorUrl>https://radicalmart.ru/</authorUrl>
	<version>1.0.0</version>
	<description>COM_RADICALMART_SEARCH_DESCRIPTION</description>
	<namespace path="src">Joomla\Component\RadicalMartSearch</namespace>
	<scriptfile>script.php</scriptfile>
	<files folder="site">
		<folder>forms</folder>
		<folder>src</folder>
		<folder>tmpl</folder>
	</files>
	<languages folder="site/language">
		<language tag="en-GB">en-GB/com_radicalmart_search.ini</language>
