		<languages folder="admin/language">
			<language tag="en-GB">en-GB/com_radicalmart_search.ini</language>
			<language tag="en-GB">en-GB/com_radicalmart_search.sys.ini</language>
			<language tag="ru-RU">ru-RU/com_radicalmart_search.ini</language>
			<language tag="ru-RU">ru-RU/com_radicalmart_search.sys.ini</language>
		</languages>
	</administration>
	<media destination="com_radicalmart_search" folder="media">
		<folder>js</folder>
		<filename>joomla.asset.json</filename>
	</media>
	<layouts destination="components/radicalmart_search" folder="layouts">
		<folder>field</folder>
	</layouts>
